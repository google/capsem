---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.svelte";
import Footer from "../../components/Footer.svelte";
import "../../styles/global.css";

const releases = [
  {
    version: "0.9",
    date: "2026-03-20",
    summary: "Setup wizard, MCP gateway rewrite, security presets, auto-update, crash fix, release pipeline.",
  },
  {
    version: "0.8",
    date: "2026-03-07",
    summary: "Unified audit database, MCP gateway, filesystem watcher, benchmarks, squashfs rootfs, apt-get support.",
  },
];
---
<Base title="News -- Capsem">
  <Nav client:load />
  <main class="max-w-3xl mx-auto px-6 py-24">
    <h1 class="text-3xl font-semibold text-heading-dark mb-12">Releases</h1>
    <div class="space-y-6">
      {releases.map((r) => (
        <a href={`/news/${r.version}`} class="block group border border-border-dark rounded-lg p-6 hover:border-accent/50 transition-colors">
          <div class="flex items-baseline justify-between mb-2">
            <h2 class="text-lg font-semibold text-white group-hover:text-accent transition-colors">v{r.version}</h2>
            <time class="text-sm text-muted-dark">{r.date}</time>
          </div>
          <p class="text-sm text-body-dark">{r.summary}</p>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</Base>
