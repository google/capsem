#!/bin/sh
# Capsem sandbox init script.
# Replaces /init in the initramfs.
# Mounts rootfs read-only from /dev/vda, creates writable tmpfs layers,
# then chroot into the real root.

# Mount essential filesystems
mount -t proc     proc     /proc
mount -t sysfs    sysfs    /sys
mount -t devtmpfs devtmpfs /dev
mkdir -p /dev/pts
mount -t devpts   devpts   /dev/pts

# Load kernel modules listed in /conf/modules (populated by initramfs-tools)
if [ -f /conf/modules ]; then
    while read -r mod args; do
        case "$mod" in \#*|"") continue ;; esac
        modprobe -q "$mod" $args 2>/dev/null || true
    done < /conf/modules
fi

# IMPORTANT: Wait for hardware to enumerate (including virtio_console/hvc0).
# Redirecting to /dev/console before this will fail and crash the init script.
sleep 1

# Send all output to console so we can see what happens
exec 0</dev/console 1>/dev/console 2>/dev/console

echo "[capsem-init] listing block devices..."
ls /dev/vda* 2>&1 || echo "[capsem-init] no /dev/vda found"

# Mount rootfs READ-ONLY from virtio block device.
# The kernel cmdline has 'ro' so this is always read-only.
mkdir -p /newroot
echo "[capsem-init] mounting /dev/vda..."
mount -t ext4 -o ro /dev/vda /newroot
echo "[capsem-init] mount exit: $?"

echo "[capsem-init] checking /newroot/bin/bash..."
ls /newroot/bin/bash 2>&1

# Create writable layers (tmpfs) -- ONLY these dirs are writable
mount -t tmpfs tmpfs /newroot/root
mount -t tmpfs tmpfs /newroot/tmp
mount -t tmpfs tmpfs /newroot/run
mount -t tmpfs tmpfs /newroot/var/log
mount -t tmpfs tmpfs /newroot/var/tmp

# Mount virtual filesystems fresh in the new root (not moved from initramfs).
# /proc, /sys, /dev exist as empty dirs from docker export.
# /dev/pts is created after devtmpfs is mounted (devtmpfs is writable).
mount -t proc     proc     /newroot/proc
mount -t sysfs    sysfs    /newroot/sys
mount -t devtmpfs devtmpfs /newroot/dev
mkdir -p /newroot/dev/pts
mount -t devpts   devpts   /newroot/dev/pts

# Set up environment
export TERM=xterm-256color
export HOME=/root
export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export LANG=C

echo "[capsem-init] about to chroot..."

# chroot into rootfs and launch shell.
# Redirect stderr to /newroot/dev/null (the devtmpfs mounted above).
exec chroot /newroot /bin/bash --rcfile /etc/capsem-bashrc -i 2>/newroot/dev/null

# If exec failed, don't let PID 1 exit (that causes kernel panic)
echo "[capsem-init] chroot failed, dropping to shell"
exec /bin/sh
