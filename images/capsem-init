#!/bin/sh
# Capsem sandbox init script.
# Replaces /init in the initramfs.
# Mounts squashfs rootfs from /dev/vda, stacks overlayfs (immutable lower
# + ephemeral tmpfs upper), then chroot into the real root.

# Mount essential filesystems
mount -t proc     proc     /proc
mount -t sysfs    sysfs    /sys
mount -t devtmpfs devtmpfs /dev
mkdir -p /dev/pts
mount -t devpts   devpts   /dev/pts

# Optimize block I/O: virtio performs best with 'none' scheduler (host OS handles it)
# and a larger read-ahead buffer.
for dev in /sys/block/vd*; do
    if [ -d "$dev" ]; then
        echo none > "$dev/queue/scheduler" 2>/dev/null || true
        echo 4096 > "$dev/queue/read_ahead_kb" 2>/dev/null || true
        echo 256 > "$dev/queue/nr_requests" 2>/dev/null || true
    fi
done

# Load kernel modules listed in /conf/modules (populated by initramfs-tools)
if [ -f /conf/modules ]; then
    while read -r mod args; do
        case "$mod" in \#*|"") continue ;; esac
        modprobe -q "$mod" $args 2>/dev/null || true
    done < /conf/modules
fi

# IMPORTANT: Wait for hardware to enumerate (including virtio_console/hvc0).
# Redirecting to /dev/console before this will fail and crash the init script.
sleep 1

# Send all output to console so we can see what happens
exec 0</dev/console 1>/dev/console 2>/dev/console

echo "[capsem-init] listing block devices..."
ls /dev/vda* 2>&1 || echo "[capsem-init] no /dev/vda found"

# Mount squashfs (immutable lower layer)
mkdir -p /mnt/a
echo "[capsem-init] mounting /dev/vda (squashfs)..."
mount -t squashfs /dev/vda /mnt/a
echo "[capsem-init] mount exit: $?"

# Create upper + workdir for global overlay.
# Prefer the scratch disk (vdb) if present, as it supports atomic renames,
# provides persistence, and much more space than tmpfs.
UPPER=""
WORK=""
SCRATCH=""
if [ -b /dev/vdb ]; then
    SCRATCH=/dev/vdb
    echo "[capsem-init] checking scratch disk ($SCRATCH)..."
    
    # We bind-mount /dev so chroot can see the block device.
    mount --bind /dev /mnt/a/dev
    
    # Only format if the disk is not already ext4 (provides persistence!)
    if ! chroot /mnt/a /usr/bin/file -s "$SCRATCH" | grep -q "ext4"; then
        echo "[capsem-init] formatting scratch disk ($SCRATCH) as ext4..."
        chroot /mnt/a /usr/sbin/mke2fs -t ext4 -m 0 -O ^has_journal -E lazy_itable_init=1 -L scratch -q "$SCRATCH" 2>&1
    else
        echo "[capsem-init] found existing ext4 filesystem on scratch disk"
    fi
    
    mkdir -p /mnt/scratch
    if mount -t ext4 -o rw,noatime,nodiratime "$SCRATCH" /mnt/scratch; then
        echo "[capsem-init] using scratch disk for overlay upper layer"
        mkdir -p /mnt/scratch/u /mnt/scratch/w
        UPPER=/mnt/scratch/u
        WORK=/mnt/scratch/w
        
        # EXDEV Workaround: "Warm up" the upper layer by copying critical
        # directory structures. This allows dpkg to perform atomic renames 
        # that would otherwise fail on overlayfs without redirect_dir support.
        echo "[capsem-init] warming up writable layer..."
        for d in etc var/lib/dpkg usr/share/doc; do
            if [ -d "/mnt/a/$d" ]; then
                mkdir -p "/mnt/scratch/u/$d"
                cp -a "/mnt/a/$d/." "/mnt/scratch/u/$d/" 2>/dev/null
            fi
        done
    fi
    umount /mnt/a/dev
fi

if [ -z "$UPPER" ]; then
    echo "[capsem-init] using tmpfs for overlay (no scratch disk)"
    mount -t tmpfs -o size=1G tmpfs /mnt/b
    mkdir -p /mnt/b/u /mnt/b/w
    UPPER=/mnt/b/u
    WORK=/mnt/b/w
fi

# Stack overlayfs: squashfs (read-only) + writable upper
# Enable redirect_dir=on and metacopy=on to support atomic directory renames.
mkdir -p /newroot
mount -t overlay overlay \
  -o lowerdir=/mnt/a,upperdir=$UPPER,workdir=$WORK,index=on,redirect_dir=on,metacopy=on \
  /newroot || \
mount -t overlay overlay \
  -o lowerdir=/mnt/a,upperdir=$UPPER,workdir=$WORK \
  /newroot

# Mount virtual filesystems fresh in the new root.
mount -t proc     proc     /newroot/proc
mount -t sysfs    sysfs    /newroot/sys
mount -t devtmpfs devtmpfs /newroot/dev
mkdir -p /newroot/dev/pts
mount -t devpts   devpts   /newroot/dev/pts

# Enable swap if we have a scratch disk
if [ -d /mnt/scratch ]; then
    # Create a 1GB swap file on the scratch disk if it doesn't exist.
    if [ ! -f /mnt/scratch/swapfile ]; then
        echo "[capsem-init] creating 1GB swapfile..."
        dd if=/dev/zero of=/mnt/scratch/swapfile bs=1M count=1024 2>/dev/null
        chmod 600 /mnt/scratch/swapfile
        # Format swap using host-side tool if possible
        mkswap /mnt/scratch/swapfile >/dev/null 2>&1 || true
    fi
    swapon /mnt/scratch/swapfile 2>/dev/null
    echo "[capsem-init] swap enabled"
fi

# === Network: air-gapped IP stack ===
# The guest has no real NIC. We create a dummy interface with a local IP,
# run a fake DNS that resolves everything to that IP, and use iptables to
# redirect port 443 to our vsock-backed proxy. The host SNI proxy then
# inspects TLS ClientHello for the domain and bridges to the real server.
echo "[capsem-init] setting up network..."

# Clean up legacy HTTP sources from the base image to ensure HTTPS is used.
rm -f /newroot/etc/apt/sources.list
mkdir -p /newroot/etc/apt/sources.list.d
# Optional: force-unsafe-io for dpkg to avoid atomic rename issues on overlayfs.
mkdir -p /newroot/etc/dpkg/dpkg.cfg.d
echo "force-unsafe-io" > /newroot/etc/dpkg/dpkg.cfg.d/force-unsafe-io

chroot /newroot ip link set lo up 2>/dev/null || true
chroot /newroot ip link add dummy0 type dummy
chroot /newroot ip addr add 10.0.0.1/24 dev dummy0
chroot /newroot ip link set dummy0 up
chroot /newroot ip route add default dev dummy0

# Fake DNS: all domains resolve to 10.0.0.1.
# Bind-mount resolv.conf from /run to ensure dnsmasq config takes effect.
echo "nameserver 127.0.0.1" > /newroot/run/resolv.conf
mount --bind /newroot/run/resolv.conf /newroot/etc/resolv.conf
chroot /newroot dnsmasq --no-daemon --no-resolv --no-hosts \
    --address=/#/10.0.0.1 --listen-address=127.0.0.1 --port=53 &
sleep 0.2

# iptables REDIRECT: use iptables-legacy since kernel has NF_TABLES=n.
IPTABLES=iptables
if [ -x /newroot/usr/sbin/iptables-legacy ]; then
    IPTABLES=iptables-legacy
fi
chroot /newroot "$IPTABLES" -t nat -A OUTPUT -p tcp --dport 443 -j REDIRECT --to-port 10443
echo "[capsem-init] network ready"

# Launch net proxy (TCP->vsock bridge) as background process.
# Prefer initrd-bundled copy, fall back to rootfs.
NET_PROXY_PATH=""
if [ -x /capsem-net-proxy ]; then
    cp /capsem-net-proxy /newroot/run/capsem-net-proxy
    chmod 555 /newroot/run/capsem-net-proxy
    NET_PROXY_PATH=/run/capsem-net-proxy
elif [ -x /newroot/usr/local/bin/capsem-net-proxy ]; then
    NET_PROXY_PATH=/usr/local/bin/capsem-net-proxy
fi
if [ -n "$NET_PROXY_PATH" ]; then
    chroot /newroot "$NET_PROXY_PATH" &
    sleep 0.1
    echo "[capsem-init] net-proxy started"
else
    echo "[capsem-init] WARNING: capsem-net-proxy not found, no HTTPS proxy"
fi

# Deploy MCP server binary (stdio-to-vsock relay for AI agents).
# Prefer initrd-bundled copy, fall back to rootfs.
if [ -x /capsem-mcp-server ]; then
    cp /capsem-mcp-server /newroot/run/capsem-mcp-server
    chmod 555 /newroot/run/capsem-mcp-server
    echo "[capsem-init] mcp-server deployed"
elif [ -x /newroot/usr/local/bin/capsem-mcp-server ]; then
    cp /newroot/usr/local/bin/capsem-mcp-server /newroot/run/capsem-mcp-server
    chmod 555 /newroot/run/capsem-mcp-server
    echo "[capsem-init] mcp-server deployed (from rootfs)"
fi

# Raise inotify watch limit for filesystem watcher.
echo 65536 > /proc/sys/fs/inotify/max_user_watches 2>/dev/null || true

# Launch filesystem watcher (inotify->vsock bridge) as background process.
# Prefer initrd-bundled copy, fall back to rootfs.
FS_WATCH_PATH=""
if [ -x /capsem-fs-watch ]; then
    cp /capsem-fs-watch /newroot/run/capsem-fs-watch
    chmod 555 /newroot/run/capsem-fs-watch
    FS_WATCH_PATH=/run/capsem-fs-watch
elif [ -x /newroot/usr/local/bin/capsem-fs-watch ]; then
    FS_WATCH_PATH=/usr/local/bin/capsem-fs-watch
fi
if [ -n "$FS_WATCH_PATH" ]; then
    chroot /newroot "$FS_WATCH_PATH" &
    sleep 0.1
    echo "[capsem-init] fs-watch started"
else
    echo "[capsem-init] WARNING: capsem-fs-watch not found, no file telemetry"
fi

# Deploy initrd-bundled capsem-doctor and diagnostics (fast iteration).
# Overwrites rootfs copies via the overlayfs upper layer.
if [ -x /capsem-doctor ]; then
    cp /capsem-doctor /newroot/usr/local/bin/capsem-doctor
    chmod 755 /newroot/usr/local/bin/capsem-doctor
    echo "[capsem-init] capsem-doctor deployed"
fi
if [ -d /diagnostics ]; then
    cp -a /diagnostics/* /newroot/usr/local/lib/capsem-tests/
    echo "[capsem-init] diagnostics deployed"
fi

# Increase open file descriptor limit to prevent EMFILE/Errno 24 crashes
ulimit -n 65536

# Set up environment (capsem-init defaults; the PTY agent overrides these
# with values from the host's BootConfig message at vsock handshake time).
export TERM=xterm-256color
export COLORTERM=truecolor
export HOME=/root
export PATH=/root/.npm-global/bin:/root/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export LANG=C

# Signal to AI CLIs that we are inside a sandbox (allows root + bypass permissions).
export IS_SANDBOX=1

# Optimize Node.js and Python for the sandboxed VM environment
# 1. Prevent kernel OOMs by capping Node's V8 heap (VM has 4GB RAM by default)
export NODE_OPTIONS="--max-old-space-size=2048"
# 2. Disable slow network checks and ads during CLI executions
export NO_UPDATE_NOTIFIER=1
export NPM_CONFIG_UPDATE_NOTIFIER=false
export NPM_CONFIG_FUND=false
export NPM_CONFIG_AUDIT=false
export PIP_DISABLE_PIP_VERSION_CHECK=1

# Create Python virtualenv so pip/uv installs go to the scratch disk.
# --system-site-packages: inherit pre-installed packages (numpy, requests, etc.)
# from the squashfs rootfs while allowing new installs into the writable venv.
# uv venv is ~100ms; fall back to stdlib venv if uv is missing.
chroot /newroot uv venv --system-site-packages /root/.venv 2>/dev/null || \
    chroot /newroot python3 -m venv --system-site-packages /root/.venv 2>/dev/null || true

# Copy AI CLIs from rootfs staging area to writable scratch disk.
# They need to be mutable because they self-update at runtime.
# Also serves as the npm global prefix so `npm install -g` works.
if [ -d /newroot/opt/ai-clis ]; then
    cp -a /newroot/opt/ai-clis /newroot/root/.npm-global
    echo "[capsem-init] AI CLIs copied to scratch disk"
else
    mkdir -p /newroot/root/.npm-global
fi
chroot /newroot npm config set prefix /root/.npm-global 2>/dev/null || true

echo "[capsem-init] about to chroot..."

# Launch the PTY agent for vsock-based terminal I/O.
# The agent creates a PTY pair, forks bash, and bridges via vsock to the host.
# This gives full terminal features (resize, job control, TUI apps) and
# high-throughput I/O without serial bottlenecks.
#
# Prefer initrd-bundled agent (injected by `just repack`) over rootfs copy.
# This allows fast agent iteration without a full rootfs rebuild.
AGENT_PATH=""
if [ -x /capsem-pty-agent ]; then
    # Copy from initrd to writable tmpfs so chroot can access it.
    # Read-only + execute (555): prevent guest processes from modifying the agent.
    cp /capsem-pty-agent /newroot/run/capsem-pty-agent
    chmod 555 /newroot/run/capsem-pty-agent
    AGENT_PATH=/run/capsem-pty-agent
    echo "[capsem-init] using initrd-bundled agent"
elif [ -x /newroot/usr/local/bin/capsem-pty-agent ]; then
    AGENT_PATH=/usr/local/bin/capsem-pty-agent
    echo "[capsem-init] using rootfs agent"
else
    echo "[capsem-init] FATAL: capsem-pty-agent not found"
    echo "[capsem-init] Rebuild with 'just build' or 'just repack'"
    # Keep PID 1 alive to prevent kernel panic, but no shell is started.
    while true; do sleep 60; done
fi

echo "[capsem-init] starting PTY agent (vsock mode)"
chroot /newroot "$AGENT_PATH"

# If bash exits (e.g. user types 'exit'), keep PID 1 alive to prevent kernel panic.
while true; do sleep 1; done
