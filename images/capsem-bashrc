# Capsem sandbox shell config

# Terminal setup (xterm.js renders in the browser)
# Note: stderr stays on the PTY (not redirected to /dev/hvc0) so that
# readline's prompt output goes through the vsock terminal path.
export TERM=xterm-256color
export LANG=C
export HISTSIZE=500
export HISTFILE=/root/.bash_history
export HOME=/root
cd /root

# Prompt: green bold "capsem" with blue directory
PS1='\[\033[1;32m\]capsem\[\033[0m\]:\[\033[1;34m\]\w\[\033[0m\]\$ '

# Color aliases
alias ls='ls --color=auto'
alias ll='ls -la --color=auto'
alias grep='grep --color=auto'

# Clear screen and show welcome banner
printf '\033[2J\033[H'
echo ""
echo -e "\033[1;32m  CAPSEM sandbox ready\033[0m"
echo -e "\033[0;36m  Linux $(uname -r) | $(uname -m)\033[0m"
echo ""
echo -e "\033[0;37m  Dev:  python3  node  npm  git  vim\033[0m"
echo -e "\033[0;37m  AI:   claude   gemini   codex\033[0m"
echo -e "\033[0;37m  Test: capsem-test\033[0m"
echo ""
