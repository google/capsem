# Build a populated rootfs for the capsem VM.
# Contains developer tools, runtimes, and AI coding CLIs.
# Mounted read-only at boot; only /root is writable (tmpfs).

FROM --platform=linux/arm64 debian:bookworm-slim

# Core utilities and inspection tools
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        coreutils util-linux procps psmisc findutils diffutils \
        lsof strace file less man-db \
        grep sed gawk \
        tar gzip bzip2 xz-utils \
        vim-tiny \
        git \
        curl ca-certificates \
        iproute2 iptables dnsmasq \
        python3 python3-pip python3-venv \
        nodejs npm && \
    ln -sf vim.tiny /usr/bin/vim && \
    rm -rf /var/lib/apt/lists/*

# AI coding CLIs (installed globally via npm)
RUN npm install -g \
        @anthropic-ai/claude-code \
        @google/gemini-cli \
        @openai/codex && \
    npm cache clean --force

# Install MITM CA certificate into system trust store
# (copied into images/ by build.py before docker build)
COPY capsem-ca.crt /usr/local/share/ca-certificates/capsem-ca.crt
RUN update-ca-certificates

# Patch certifi's CA bundle (Python requests/openai SDK use certifi, not system store)
RUN pip3 install --break-system-packages certifi && \
    CERTIFI_BUNDLE=$(python3 -c "import certifi; print(certifi.where())") && \
    cat /usr/local/share/ca-certificates/capsem-ca.crt >> "$CERTIFI_BUNDLE"

# PTY agent binary (built externally, cross-compiled for aarch64-linux-musl)
# Bridges PTY I/O over vsock for high-performance terminal communication.
# Read-only + execute (555): prevent guest processes from modifying the agent.
COPY capsem-pty-agent /usr/local/bin/capsem-pty-agent
RUN chmod 555 /usr/local/bin/capsem-pty-agent

# Net proxy binary (cross-compiled for aarch64-linux-musl)
# Bridges TCP connections from the guest to the host SNI proxy via vsock.
COPY capsem-net-proxy /usr/local/bin/capsem-net-proxy
RUN chmod 555 /usr/local/bin/capsem-net-proxy

# Shell config (sourced by capsem-init via --rcfile)
COPY capsem-bashrc /etc/capsem-bashrc

# Pytest for VM diagnostics
RUN pip3 install --break-system-packages pytest

# Diagnostic test suite
COPY diagnostics/ /usr/local/lib/capsem-tests/

# Doctor script (entry point)
COPY capsem-doctor /usr/local/bin/capsem-doctor
RUN chmod 755 /usr/local/bin/capsem-doctor
# Backward compat: capsem-test -> capsem-doctor
RUN ln -sf capsem-doctor /usr/local/bin/capsem-test

# Strip setuid/setgid bits from all binaries (VM runs as root, no need for them).
RUN find / -xdev \( -perm -4000 -o -perm -2000 \) -type f -exec chmod u-s,g-s {} + 2>/dev/null || true

# /root is a tmpfs at runtime, so don't put anything here
RUN rm -rf /root && mkdir -p /root
