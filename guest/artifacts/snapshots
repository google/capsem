#!/usr/bin/env python3
"""snapshots -- manage VM workspace snapshots.

Usage:
    snapshots create [name]          Create a named snapshot
    snapshots list                   List all snapshots with file changes
    snapshots changes                List changed files since checkpoints
    snapshots revert <path> [cp]     Revert a file (latest snapshot if cp omitted)
    snapshots delete <cp>            Delete a manual snapshot

Options:
    --json    Output raw JSON instead of formatted tables
"""

import asyncio
import atexit
import json
import sys
from datetime import datetime

from fastmcp import Client
from fastmcp.client.transports import StdioTransport

MCP_SERVER = "/run/capsem-mcp-server"

# Persistent MCP client -- reused across all call_tool() invocations.
# Avoids ~270ms fastmcp import + ~100ms subprocess/handshake per call.
_client = None


async def _get_client():
    global _client
    if _client is None:
        _client = Client(StdioTransport(command=MCP_SERVER, args=[]))
        await _client.__aenter__()
    return _client


async def _close_client():
    global _client
    if _client is not None:
        try:
            await _client.__aexit__(None, None, None)
        except Exception:
            pass
        _client = None


def _cleanup():
    if _client is not None:
        try:
            asyncio.get_event_loop().run_until_complete(_close_client())
        except Exception:
            pass

atexit.register(_cleanup)


async def call_tool(name, arguments=None):
    """Call an MCP tool via capsem-mcp-server and return parsed result."""
    client = await _get_client()
    result = await client.call_tool(name, arguments or {})

    for block in result.content:
        if hasattr(block, "text"):
            return block.text
    return ""


def parse_json_text(text):
    """Try to parse text as JSON, return raw string on failure."""
    try:
        return json.loads(text)
    except (json.JSONDecodeError, TypeError):
        return text


def cmd_create(args, as_json):
    name = args[0] if args else datetime.now().strftime("%Y%m%d_%H%M%S")
    text = asyncio.run(call_tool("snapshots_create", {"name": name}))
    data = parse_json_text(text)

    if as_json:
        print(json.dumps(data, indent=2))
        return

    if isinstance(data, dict):
        print(f"Snapshot created: {data.get('checkpoint', '?')}")
        print(f"  Name: {data.get('name', '?')}")
        print(f"  Hash: {data.get('hash', '?')}")
        print(f"  Available slots: {data.get('available', '?')}")
    else:
        print(data)


def cmd_list(_args, as_json):
    if as_json:
        text = asyncio.run(call_tool("snapshots_list", {"format": "json"}))
        data = parse_json_text(text)
        print(json.dumps(data, indent=2))
    else:
        # MCP returns pre-formatted text table with pagination.
        text = asyncio.run(call_tool("snapshots_list"))
        print(text)


def cmd_changes(_args, as_json):
    if as_json:
        text = asyncio.run(call_tool("snapshots_changes", {"format": "json"}))
        data = parse_json_text(text)
        print(json.dumps(data, indent=2))
    else:
        # MCP returns pre-formatted text table with pagination.
        text = asyncio.run(call_tool("snapshots_changes"))
        print(text)


def cmd_revert(args, as_json):
    if not args:
        print("Usage: snapshots revert <path> [checkpoint]", file=sys.stderr)
        sys.exit(1)
    arguments = {"path": args[0]}
    if len(args) >= 2:
        arguments["checkpoint"] = args[1]
    text = asyncio.run(call_tool("snapshots_revert", arguments))
    data = parse_json_text(text)

    if as_json:
        print(json.dumps(data, indent=2))
        return

    if isinstance(data, dict) and data.get("reverted"):
        action = data.get("action", "reverted")
        cp = data.get("checkpoint", "?")
        print(f"Reverted: {data.get('path', args[0])}")
        print(f"  Checkpoint: {cp}")
        print(f"  Action: {action}")
    else:
        print(data)


def cmd_delete(args, as_json):
    if not args:
        print("Usage: snapshots delete <checkpoint>", file=sys.stderr)
        sys.exit(1)
    checkpoint = args[0]
    text = asyncio.run(call_tool("snapshots_delete", {"checkpoint": checkpoint}))
    data = parse_json_text(text)

    if as_json:
        print(json.dumps(data, indent=2))
        return

    if isinstance(data, dict) and data.get("deleted"):
        print(f"Deleted snapshot: {checkpoint}")
    else:
        print(data)


def cmd_history(args, as_json):
    if not args:
        print("Usage: snapshots history <path>", file=sys.stderr)
        sys.exit(1)
    text = asyncio.run(call_tool("snapshots_history", {"path": args[0]}))
    data = parse_json_text(text)

    if as_json:
        print(json.dumps(data, indent=2))
        return

    if isinstance(data, dict):
        versions = data.get("versions", [])
        path = data.get("path", args[0])
        current_size = data.get("current_size")
        print(f"History: {path} (current: {current_size or 'deleted'}B)")
        if not versions:
            print("  No snapshots contain this file.")
            return
        from rich.console import Console
        from rich.table import Table

        table = Table()
        table.add_column("Checkpoint", style="cyan")
        table.add_column("Origin")
        table.add_column("Name")
        table.add_column("Age")
        table.add_column("Size")
        table.add_column("Status")
        for v in versions:
            status = v.get("status", "?")
            status_style = {
                "unchanged": "dim", "modified": "yellow",
                "deleted_since": "red", "created_since": "green",
            }.get(status, "white")
            size = v.get("size")
            size_str = str(size) if size is not None else "-"
            table.add_row(
                v.get("checkpoint", "?"),
                v.get("origin", "?"),
                v.get("name") or "-",
                v.get("age", "?"),
                size_str,
                f"[{status_style}]{status}[/{status_style}]",
            )
        Console().print(table)
    else:
        print(data)


def cmd_compact(args, as_json):
    if len(args) < 2:
        print("Usage: snapshots compact <cp1> <cp2> [cp3...] [--name NAME]", file=sys.stderr)
        sys.exit(1)
    checkpoints = []
    name = None
    i = 0
    while i < len(args):
        if args[i] == "--name" and i + 1 < len(args):
            name = args[i + 1]
            i += 2
        else:
            checkpoints.append(args[i])
            i += 1
    arguments = {"checkpoints": checkpoints}
    if name:
        arguments["name"] = name
    text = asyncio.run(call_tool("snapshots_compact", arguments))
    data = parse_json_text(text)

    if as_json:
        print(json.dumps(data, indent=2))
        return

    if isinstance(data, dict) and data.get("compacted"):
        print(f"Compacted {data.get('merged_count', '?')} snapshots into {data.get('checkpoint', '?')}")
        print(f"  Name: {data.get('name', '?')}")
        print(f"  Hash: {data.get('hash', '?')}")
        print(f"  Files: {data.get('files_count', '?')}")
        deleted = data.get("deleted_checkpoints", [])
        print(f"  Deleted: {', '.join(deleted)}")
    else:
        print(data)


COMMANDS = {
    "create": cmd_create,
    "list": cmd_list,
    "changes": cmd_changes,
    "history": cmd_history,
    "compact": cmd_compact,
    "revert": cmd_revert,
    "delete": cmd_delete,
}

USAGE = """Usage: snapshots <command> [args...]

Commands:
    create [name]          Create a named snapshot
    list                   List all snapshots with file changes
    changes                List changed files since checkpoints
    history <path>         Show all versions of a file across snapshots
    compact <cp> <cp> ...  Merge snapshots into one (--name NAME)
    revert <path> [cp]     Revert a file (latest snapshot if cp omitted)
    delete <cp>            Delete a manual snapshot

Options:
    --json                 Output raw JSON"""


def main():
    args = sys.argv[1:]
    as_json = "--json" in args
    if as_json:
        args.remove("--json")

    if not args or args[0] in ("-h", "--help"):
        print(USAGE)
        sys.exit(0)

    cmd = args[0]
    if cmd not in COMMANDS:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        print(USAGE, file=sys.stderr)
        sys.exit(1)

    try:
        COMMANDS[cmd](args[1:], as_json)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
