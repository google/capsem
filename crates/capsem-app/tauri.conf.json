{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Capsem",
  "version": "0.12.1",
  "identifier": "com.capsem.capsem",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Capsem",
        "label": "main",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "resources": {
      "../../assets/vmlinuz": "vmlinuz",
      "../../assets/initrd.img": "initrd.img",
      "../../assets/manifest.json": "manifest.json"
    },
    "macOS": {
      "entitlements": "../../entitlements.plist",
      "minimumSystemVersion": "13.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk2RTIxOTI5RDUxRkU3NDIKUldSQzV4L1ZLUm5pbGhrdVQ2Y0dhbE11NlJPSlNRTzBrWVpFUkV1VkFuZEgyNjVza2lSNWV2S3QK",
      "endpoints": [
        "https://github.com/google/capsem/releases/latest/download/latest.json"
      ]
    }
  }
}
