{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Capsem",
  "version": "0.6.0",
  "identifier": "com.capsem.capsem",
  "build": {
    "beforeDevCommand": "pnpm --filter capsem-frontend dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter capsem-frontend build",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Capsem",
        "label": "main",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "createUpdaterArtifacts": false,
    "resources": {
      "../../assets/vmlinuz": "",
      "../../assets/initrd.img": "",
      "../../assets/rootfs.img": "",
      "../../assets/B3SUMS": ""
    },
    "macOS": {
      "entitlements": "../../entitlements.plist",
      "minimumSystemVersion": "13.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDODFGODlFMkM2M0FCODAKUldTQXEyTXNudmlCVEM4elUxVk9aTUEvK2xldjdJY25QUEdBK2VsTWdUSTlFQVB5dG5TZmhxbjcK",
      "endpoints": [
        "https://github.com/google/capsem/releases/latest/download/latest.json"
      ]
    }
  }
}
