# Build a populated rootfs for the capsem VM.
# Contains developer tools, runtimes, and AI coding CLIs.
# Mounted read-only at boot; only /root is writable (tmpfs).
# Architecture: {{ arch_name }} ({{ arch.docker_platform }})
# Generated by capsem-builder from guest/config/ TOML files.

FROM --platform={{ arch.docker_platform }} {{ arch.base_image }}

# Core utilities and inspection tools
# apt-get upgrade pulls latest security patches and package versions at build time.
RUN apt-get -o Acquire::Check-Valid-Until=false -o Acquire::Check-Date=false update && \
    apt-get upgrade -y && \
    apt-get install -y --no-install-recommends \
        {{ apt_packages | join(' \\\n        ') }} && \
    ln -sf vim.tiny /usr/bin/vim && \
    pip3 install --break-system-packages --upgrade pip

# Node.js {{ arch.node_major }} LTS via nvm (Debian bookworm ships v18 which lacks the 'v'
# regex flag needed by modern npm packages like @google/gemini-cli).
# nvm install script always fetches latest release. npm upgraded to latest after.
ENV NVM_DIR=/usr/local/nvm
RUN mkdir -p $NVM_DIR && \
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/master/install.sh | bash && \
    bash -c '. $NVM_DIR/nvm.sh && nvm install {{ arch.node_major }} && npm install -g npm@latest && \
    for bin in node npm npx; do ln -sf "$(which $bin)" /usr/local/bin/$bin; done'

# uv -- fast Python package installer (also available to guest AI agents)
RUN curl -LsSf https://astral.sh/uv/install.sh | env INSTALLER_NO_MODIFY_PATH=1 sh && \
    install -m 555 /root/.local/bin/uv /usr/local/bin/uv && \
    install -m 555 /root/.local/bin/uvx /usr/local/bin/uvx

{% if npm_packages %}
# AI coding CLIs -- installed to {{ npm_prefix }}.
# Writable at runtime via overlayfs upper layer so CLIs can self-update.
RUN npm install -g --prefix {{ npm_prefix }} \
        {{ npm_packages | join(' \\\n        ') }} && \
    npm config set prefix {{ npm_prefix }} -g && \
    npm cache clean --force
ENV PATH="{{ npm_prefix }}/bin:$PATH"
{% endif %}

# Install MITM CA certificate into system trust store
# (copied into build context by capsem-builder before docker build)
COPY capsem-ca.crt /usr/local/share/ca-certificates/capsem-ca.crt
RUN update-ca-certificates

# Patch certifi's CA bundle (Python requests/openai SDK use certifi, not system store)
RUN uv pip install --system --break-system-packages certifi && \
    CERTIFI_BUNDLE=$(python3 -c "import certifi; print(certifi.where())") && \
    cat /usr/local/share/ca-certificates/capsem-ca.crt >> "$CERTIFI_BUNDLE"

{% for binary in guest_binaries %}
# {{ binary }} (cross-compiled for {{ arch.rust_target }})
COPY {{ binary }} /usr/local/bin/{{ binary }}
RUN chmod 555 /usr/local/bin/{{ binary }}

{% endfor %}
# Shell config (sourced by capsem-init via --rcfile)
COPY capsem-bashrc /etc/capsem-bashrc
COPY banner.txt /etc/capsem-banner.txt
COPY tips.txt /etc/capsem-tips.txt

{% if python_packages %}
# Common Python packages (pre-installed so they're available immediately).
# The boot-time venv uses --system-site-packages to inherit these.
# Agents can still pip/uv install additional packages into the venv.
RUN {{ python_install_cmd }} \
        {{ python_packages | join(' \\\n        ') }}
{% endif %}

# Diagnostic test suite
COPY diagnostics/ /usr/local/lib/capsem-tests/

# Doctor script (entry point)
COPY capsem-doctor /usr/local/bin/capsem-doctor
RUN chmod 755 /usr/local/bin/capsem-doctor
# Backward compat: capsem-test -> capsem-doctor
RUN ln -sf capsem-doctor /usr/local/bin/capsem-test

# Bench tool (disk I/O + HTTP performance benchmarks)
COPY capsem-bench /usr/local/bin/capsem-bench
RUN chmod 555 /usr/local/bin/capsem-bench
COPY capsem_bench/ /usr/local/lib/capsem_bench/

# Snapshot management CLI
COPY snapshots /usr/local/bin/snapshots
RUN chmod 555 /usr/local/bin/snapshots

# Remove PEP 668 EXTERNALLY-MANAGED marker.
# This is an ephemeral sandboxed VM -- the protection is unnecessary and blocks
# pip install with a confusing error.  A pre-activated venv handles writes
# (since the rootfs is read-only) but removing the marker is belt-and-suspenders
# so any stray pip invocation outside the venv gives a real error, not PEP 668.
RUN rm -f /usr/lib/python*/EXTERNALLY-MANAGED

# Strip setuid/setgid bits from all binaries (VM runs as root, no need for them).
RUN find / -xdev \( -perm -4000 -o -perm -2000 \) -type f -exec chmod u-s,g-s {} + 2>/dev/null || true

# /root is a tmpfs at runtime, so don't put anything here
RUN rm -rf /root && mkdir -p /root

{% for url in curl_installs %}
# CLI installed via installer script
# The installer puts binaries in ~/.local/bin/. Since /root is a tmpfs at
# runtime (overlayfs), copy to /usr/local/bin so they survive boot.
RUN curl -fsSL {{ url }} | bash && \
    for bin in /root/.local/bin/*; do \
        [ -f "$bin" ] && install -m 555 "$bin" /usr/local/bin/; \
    done
{% endfor %}

# Switch apt sources to HTTPS for runtime use.
# Build uses HTTP (ca-certificates not available earlier); VM blocks port 80.
RUN sed -i 's|URIs: http://|URIs: https://|g' /etc/apt/sources.list.d/debian.sources
