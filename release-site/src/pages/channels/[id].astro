---
import ReleaseLayout from '../../layouts/ReleaseLayout.astro';
import {
  binaryDescription,
  binaryRows,
  byteLabel,
  channelProfilePagePath,
  channelRows,
  dataForChannel,
  generatedAt,
  hashLabel,
  hostSbomRows,
  loadReleaseData,
  manifestBlake3,
  manifestRecords,
  manifestUrl,
  packageRows,
  profileArchNames,
  profileCatalogUrl,
  profileList,
} from '../../lib/release-data';

export function getStaticPaths() {
  const rootData = loadReleaseData();
  return channelRows(rootData).map((channel) => ({
    params: { id: channel.id },
    props: {
      channel,
      data: dataForChannel(rootData, channel.id),
    },
  }));
}

const { channel, data } = Astro.props;
const manifests = manifestRecords(data);
const packages = packageRows(data);
const binaries = binaryRows(data);
const hostSboms = hostSbomRows(data);
const profiles = profileList(data);
const profileCount = profiles.length;
---
<ReleaseLayout title={`${channel.label} - Capsem Release Channel`}>
  <header class="border-b border-zinc-200 pb-6">
    <a class="text-sm font-medium text-blue-600 underline" href="/">All channels</a>
    <h1 class="mt-3 text-4xl font-semibold tracking-normal text-black">{channel.label}</h1>
    <p class="mt-3 max-w-3xl text-base text-zinc-600">
      Selected manifest, Capsem package inventory, executable inventory, and profile references for <code>{channel.id}</code>.
    </p>
  </header>

  <section class="mt-8 border border-zinc-200 p-5">
    <h2 class="text-xl font-semibold text-black">Selected Manifest</h2>
    <dl class="mt-4 grid gap-3 text-sm sm:grid-cols-[12rem_1fr]">
      <dt class="text-zinc-500">Channel</dt><dd><code>{data.channel}</code></dd>
      <dt class="text-zinc-500">Generated</dt><dd><code>{generatedAt(data)}</code></dd>
      <dt class="text-zinc-500">Version</dt><dd><code>{data.manifestRecord.version}</code></dd>
      <dt class="text-zinc-500">Status</dt><dd>{data.manifestRecord.status ?? data.manifest.status ?? 'unknown'}</dd>
      <dt class="text-zinc-500">Manifest URL</dt><dd><a class="break-all text-blue-600 underline" href={manifestUrl(data)}>{manifestUrl(data)}</a></dd>
      <dt class="text-zinc-500">Channel manifest</dt><dd><a class="break-all text-blue-600 underline" href={`/assets/${data.channel}/manifest.json`}>/assets/{data.channel}/manifest.json</a></dd>
      <dt class="text-zinc-500">Profile Catalog</dt><dd><a class="break-all text-blue-600 underline" href={profileCatalogUrl(data)}>{profileCatalogUrl(data)}</a></dd>
      <dt class="text-zinc-500">Manifest SHA-256</dt><dd><code class="break-all">{hashLabel(data.manifestRecord.digest?.sha256)}</code></dd>
      <dt class="text-zinc-500">Manifest BLAKE3</dt><dd><code class="break-all">{manifestBlake3(data)}</code></dd>
      <dt class="text-zinc-500">Packages</dt><dd>{packages.length}</dd>
      <dt class="text-zinc-500">Binaries</dt><dd>{binaries.length}</dd>
      <dt class="text-zinc-500">Profiles</dt><dd>{profileCount}</dd>
    </dl>
  </section>

  <section class="mt-6 border border-zinc-200 p-5">
    <h2 class="text-xl font-semibold text-black">Manifest History</h2>
    <div class="mt-4 overflow-x-auto">
      <table class="w-full min-w-[860px] border-collapse text-sm">
        <thead>
          <tr class="border-b border-zinc-200 text-left text-zinc-500">
            <th class="py-2 pr-4 font-medium">Version</th>
            <th class="py-2 pr-4 font-medium">Status</th>
            <th class="py-2 pr-4 font-medium">Manifest URL</th>
            <th class="py-2 pr-4 font-medium">SHA-256</th>
            <th class="py-2 pr-4 font-medium">BLAKE3</th>
          </tr>
        </thead>
        <tbody>
          {manifests.map((manifest) => (
            <tr class="border-b border-zinc-100 align-top">
              <td class="py-3 pr-4"><code>{manifest.version}</code></td>
              <td class="py-3 pr-4">{manifest.status}</td>
              <td class="py-3 pr-4"><a class="break-all text-blue-600 underline" href={manifest.url}>{manifest.url}</a></td>
              <td class="py-3 pr-4"><code class="break-all">{hashLabel(manifest.digest?.sha256)}</code></td>
              <td class="py-3 pr-4"><code class="break-all">{hashLabel(manifest.digest?.blake3)}</code></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-6 border border-zinc-200 p-5">
    <h2 class="text-xl font-semibold text-black">Capsem Packages</h2>
    <div class="mt-4 overflow-x-auto">
      <table class="w-full min-w-[940px] border-collapse text-sm">
        <thead>
          <tr class="border-b border-zinc-200 text-left text-zinc-500">
            <th class="py-2 pr-4 font-medium">Kind</th>
            <th class="py-2 pr-4 font-medium">Name</th>
            <th class="py-2 pr-4 font-medium">Version</th>
            <th class="py-2 pr-4 font-medium">Download</th>
            <th class="py-2 pr-4 font-medium">Bytes</th>
            <th class="py-2 pr-4 font-medium">SHA-256</th>
            <th class="py-2 pr-4 font-medium">BLAKE3</th>
            <th class="py-2 pr-4 font-medium">SBOM</th>
          </tr>
        </thead>
        <tbody>
          {packages.length > 0 ? packages.map((pkg) => (
            <tr class="border-b border-zinc-100 align-top">
              <td class="py-3 pr-4">{pkg.kind}</td>
              <td class="py-3 pr-4">{pkg.name}</td>
              <td class="py-3 pr-4"><code>{pkg.version}</code></td>
              <td class="py-3 pr-4">{pkg.url ? <a class="break-all text-blue-600 underline" href={pkg.url}>{pkg.url}</a> : <span class="text-zinc-500">not published</span>}</td>
              <td class="py-3 pr-4">{byteLabel(pkg.bytes ?? pkg.size)}</td>
              <td class="py-3 pr-4"><code class="break-all">{hashLabel(pkg.digest?.sha256)}</code></td>
              <td class="py-3 pr-4"><code class="break-all">{hashLabel(pkg.digest?.blake3)}</code></td>
              <td class="py-3 pr-4">
                {hostSboms.length > 0 ? hostSboms.map((sbom) => (
                  <div>
                    {sbom.url ? <a class="break-all text-blue-600 underline" href={sbom.url}>{sbom.name}</a> : <span>{sbom.name}</span>}
                    <div><code class="break-all">{hashLabel(sbom.digest?.sha256)}</code></div>
                  </div>
                )) : <span class="text-zinc-500">not published</span>}
              </td>
            </tr>
          )) : (
            <tr>
              <td class="py-4 pr-4 text-zinc-600" colspan="8">No package metadata is published in this manifest.</td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-6 border border-zinc-200 p-5">
    <h2 class="text-xl font-semibold text-black">Capsem Binaries</h2>
    <div class="mt-4 overflow-x-auto">
      <table class="w-full min-w-[980px] border-collapse text-sm">
        <thead>
          <tr class="border-b border-zinc-200 text-left text-zinc-500">
            <th class="py-2 pr-4 font-medium">Version</th>
            <th class="py-2 pr-4 font-medium">Binary</th>
            <th class="py-2 pr-4 font-medium">Description</th>
            <th class="py-2 pr-4 font-medium">Installed path</th>
            <th class="py-2 pr-4 font-medium">Bytes</th>
            <th class="py-2 pr-4 font-medium">SHA-256</th>
            <th class="py-2 pr-4 font-medium">BLAKE3</th>
            <th class="py-2 pr-4 font-medium">SBOM component</th>
          </tr>
        </thead>
        <tbody>
          {binaries.length > 0 ? binaries.map((binary) => (
            <tr class="border-b border-zinc-100 align-top">
              <td class="py-3 pr-4"><code>{binary.version}</code></td>
              <td class="py-3 pr-4">{binary.name}</td>
              <td class="py-3 pr-4 text-zinc-600">{binaryDescription(binary.name)}</td>
              <td class="py-3 pr-4"><code>{binary.installed_path}</code></td>
              <td class="py-3 pr-4">{byteLabel(binary.bytes)}</td>
              <td class="py-3 pr-4"><code class="break-all">{hashLabel(binary.digest?.sha256)}</code></td>
              <td class="py-3 pr-4"><code class="break-all">{hashLabel(binary.digest?.blake3)}</code></td>
              <td class="py-3 pr-4"><code>{binary.sbom_component_ref}</code></td>
            </tr>
          )) : (
            <tr>
              <td class="py-4 pr-4 text-zinc-600" colspan="8">No executable binary inventory is published in this manifest.</td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-6 border border-zinc-200 p-5">
    <h2 class="text-xl font-semibold text-black">Profile References</h2>
    <div class="mt-4 overflow-x-auto">
      <table class="w-full min-w-[760px] border-collapse text-sm">
        <thead>
          <tr class="border-b border-zinc-200 text-left text-zinc-500">
            <th class="py-2 pr-4 font-medium">Profile</th>
            <th class="py-2 pr-4 font-medium">Revision</th>
            <th class="py-2 pr-4 font-medium">Minimum Capsem</th>
            <th class="py-2 pr-4 font-medium">Architectures</th>
          </tr>
        </thead>
        <tbody>
          {profiles.map((profile) => (
            <tr class="border-b border-zinc-100 align-top">
              <td class="py-3 pr-4">
                <a class="text-blue-600 underline" href={channelProfilePagePath(data.channel, profile.id)}>{profile.name}</a>
                <div><code>{profile.id}</code></div>
              </td>
              <td class="py-3 pr-4"><code>{profile.revision}</code></td>
              <td class="py-3 pr-4"><code>{profile.min_capsem_version ?? 'not specified'}</code></td>
              <td class="py-3 pr-4">{profileArchNames(profile).join(', ')}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</ReleaseLayout>
