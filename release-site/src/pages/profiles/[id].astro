---
import ReleaseLayout from '../../layouts/ReleaseLayout.astro';
import {
  byteLabel,
  hashLabel,
  loadReleaseData,
  profileArtifactRows,
  profileFileRows,
  profileList,
  profilePagePath,
  profileArchNames,
} from '../../lib/release-data';

export function getStaticPaths() {
  const data = loadReleaseData();
  return profileList(data).map((profile) => ({
    params: { id: profile.id },
    props: { profile, data },
  }));
}

const { profile, data } = Astro.props;
const arches = profileArchNames(profile);
const files = profileFileRows(profile);
const availability = Object.entries(profile.availability ?? {})
  .filter(([, enabled]) => enabled)
  .map(([name]) => name)
  .join(', ');
const profileName = profile.name ?? profile.id;
const profileDescription = profile.description ?? `Release profile ${profile.id}`;
const vmDefaults = profile.vm
  ? `${profile.vm.cpu_count ?? 'unknown'} CPU, ${profile.vm.ram_gb ?? 'unknown'} GB RAM, ${profile.vm.scratch_disk_size_gb ?? 'unknown'} GB scratch`
  : 'not specified';
---
<ReleaseLayout title={`${profileName} - Capsem Profile`}>
  <header class="border-b border-zinc-200 pb-6">
    <a class="text-sm font-medium text-blue-600 underline" href="/">Asset channel</a>
    <h1 class="mt-3 text-4xl font-semibold tracking-normal text-black">{profileName}</h1>
    <p class="mt-3 max-w-3xl text-base text-zinc-600">{profileDescription}</p>
  </header>

  <section class="mt-8 border border-zinc-200 p-5">
    <h2 class="text-xl font-semibold text-black">Profile</h2>
    <dl class="mt-4 grid gap-3 text-sm sm:grid-cols-[14rem_1fr]">
      <dt class="text-zinc-500">ID</dt><dd><code>{profile.id}</code></dd>
      <dt class="text-zinc-500">Revision</dt><dd><code>{profile.revision}</code></dd>
      <dt class="text-zinc-500">Status</dt><dd>{profile.status ?? data.manifest.status ?? 'current'}</dd>
      <dt class="text-zinc-500">Refresh policy</dt><dd>{profile.refresh_policy ?? 'not specified'}</dd>
      <dt class="text-zinc-500">Availability</dt><dd>{availability || 'none'}</dd>
      <dt class="text-zinc-500">Minimum Capsem</dt><dd><code>{profile.min_capsem_version ?? profile.compatibility?.min_binary ?? 'not specified'}</code></dd>
      <dt class="text-zinc-500">VM defaults</dt><dd>{vmDefaults}</dd>
    </dl>
  </section>

  <section class="mt-6 border border-zinc-200 p-5">
    <h2 class="text-xl font-semibold text-black">Architecture Files</h2>
    <div class="mt-4 space-y-8">
      {arches.map((arch) => (
        <section class="border-t border-zinc-200 pt-5">
          <h3 class="text-lg font-semibold text-black">Architecture {arch}</h3>
          <div class="mt-3 overflow-x-auto">
            <table class="w-full min-w-[820px] border-collapse text-sm">
              <thead>
                <tr class="border-b border-zinc-200 text-left text-zinc-500">
                  <th class="py-2 pr-4 font-medium">File</th>
                  <th class="py-2 pr-4 font-medium">Name</th>
                  <th class="py-2 pr-4 font-medium">URL</th>
                  <th class="py-2 pr-4 font-medium">Bytes</th>
                  <th class="py-2 pr-4 font-medium">Hash</th>
                </tr>
              </thead>
              <tbody>
                {profileArtifactRows(profile, arch).map((row) => (
                  <tr class="border-b border-zinc-100 align-top">
                    <td class="py-3 pr-4">{row.label}</td>
                    <td class="py-3 pr-4">{row.name}</td>
                    <td class="py-3 pr-4">
                      {row.url ? <a class="break-all text-blue-600 underline" href={row.url}>{row.url}</a> : <span class="text-zinc-500">{row.status ?? 'not published'}</span>}
                    </td>
                    <td class="py-3 pr-4">{row.size ? byteLabel(row.size) : 'unknown'}</td>
                    <td class="py-3 pr-4"><code class="break-all">{hashLabel(row.hash)}</code></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      ))}
    </div>
  </section>

  <section class="mt-6 border border-zinc-200 p-5">
    <h2 class="text-xl font-semibold text-black">Profile Files</h2>
    <div class="mt-4 overflow-x-auto">
      <table class="w-full min-w-[760px] border-collapse text-sm">
        <thead>
          <tr class="border-b border-zinc-200 text-left text-zinc-500">
            <th class="py-2 pr-4 font-medium">Kind</th>
            <th class="py-2 pr-4 font-medium">Path</th>
            <th class="py-2 pr-4 font-medium">Bytes</th>
            <th class="py-2 pr-4 font-medium">BLAKE3</th>
          </tr>
        </thead>
        <tbody>
          {files.map((file) => (
            <tr class="border-b border-zinc-100 align-top">
              <td class="py-3 pr-4">{file.label}</td>
              <td class="py-3 pr-4">{file.name}</td>
              <td class="py-3 pr-4">{byteLabel(file.size)}</td>
              <td class="py-3 pr-4"><code class="break-all">{hashLabel(file.hash)}</code></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <nav class="mt-8 flex flex-wrap gap-4 text-sm">
    <a class="font-medium text-blue-600 underline" href="/">Release overview</a>
    {profileList(data).map((item) => (
      item.id !== profile.id ? <a class="font-medium text-blue-600 underline" href={profilePagePath(item.id)}>{item.name}</a> : null
    ))}
  </nav>
</ReleaseLayout>
