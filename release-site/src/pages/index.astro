---
import ReleaseLayout from '../layouts/ReleaseLayout.astro';
import { channelRows, generatedAt, loadReleaseData } from '../lib/release-data';

const data = loadReleaseData();
const channels = channelRows(data);
---
<ReleaseLayout title="Capsem Release Channels">
  <header class="border-b border-zinc-200 pb-6">
    <p class="text-sm font-medium text-blue-600">release.capsem.org</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-normal text-black">Capsem Release Channels</h1>
    <p class="mt-3 max-w-3xl text-base text-zinc-600">
      Public channel catalog generated from <code>channels.json</code>.
    </p>
  </header>

  <section class="mt-8 border border-zinc-200 p-5">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 class="text-xl font-semibold text-black">Channels</h2>
        <p class="mt-1 text-sm text-zinc-600">Generated {generatedAt(data)}</p>
      </div>
      <a class="text-sm font-medium text-blue-600 underline" href="/channels.json">channels.json</a>
    </div>
    <div class="mt-4 overflow-x-auto">
      <table class="w-full min-w-[760px] border-collapse text-sm">
        <thead>
          <tr class="border-b border-zinc-200 text-left text-zinc-500">
            <th class="py-2 pr-4 font-medium">Channel</th>
            <th class="py-2 pr-4 font-medium">Selected manifest</th>
            <th class="py-2 pr-4 font-medium">Status</th>
            <th class="py-2 pr-4 font-medium">Records</th>
            <th class="py-2 pr-4 font-medium">Manifest URL</th>
          </tr>
        </thead>
        <tbody>
          {channels.map((channel) => (
            <tr class="border-b border-zinc-100 align-top" id={`channel-${channel.id}`}>
              <td class="py-3 pr-4">
                <div class="font-medium text-black">
                  <a class="text-blue-600 underline" href={channel.pageUrl}>{channel.label}</a>
                </div>
                <code>{channel.id}</code>
              </td>
              <td class="py-3 pr-4"><code>{channel.currentVersion}</code></td>
              <td class="py-3 pr-4">{channel.currentStatus}</td>
              <td class="py-3 pr-4">
                {channel.manifestCount}
                <span class="ml-2 text-zinc-500">{channel.statuses.join(', ')}</span>
              </td>
              <td class="py-3 pr-4">
                <a class="break-all text-blue-600 underline" href={channel.manifestUrl}>{channel.manifestUrl}</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</ReleaseLayout>
