---
import ReleaseLayout from '../layouts/ReleaseLayout.astro';
import {
  assetReleaseRows,
  binaryDescription,
  binaryRows,
  byteLabel,
  currentAssetBaseUrl,
  currentArchitectures,
  hostSbomRows,
  loadReleaseData,
  profileList,
  profilePagePath,
} from '../lib/release-data';

const data = loadReleaseData();
const health = data.health;
const profiles = profileList(data);
const binaries = binaryRows(data);
const hostSboms = hostSbomRows(data);
const assetReleases = assetReleaseRows(data);
const architectures = currentArchitectures(data);
const hostSbom = hostSboms[0];
const assetBase = currentAssetBaseUrl(data);
---
<ReleaseLayout title="Capsem Asset Channel">
  <header class="border-b border-zinc-200 pb-6">
    <p class="text-sm font-medium text-blue-600">release.capsem.org</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-normal text-black">Capsem Asset Channel</h1>
    <p class="mt-3 max-w-3xl text-base text-zinc-600">
      Current binary, VM asset, profile, and evidence inventory for the public Capsem release channel.
    </p>
  </header>

  <section class="mt-8 border border-zinc-200 p-5">
    <h2 class="text-xl font-semibold text-black">Channel Manifest</h2>
    <dl class="mt-4 grid gap-3 text-sm sm:grid-cols-[14rem_1fr]">
      <dt class="text-zinc-500">Channel</dt><dd>{health.channel}</dd>
      <dt class="text-zinc-500">Generated</dt><dd>{health.generated_at}</dd>
      <dt class="text-zinc-500">Manifest URL</dt><dd><a class="break-all text-blue-600 underline" href={health.urls.manifest}>{health.urls.manifest}</a></dd>
      <dt class="text-zinc-500">Binary revision</dt><dd><code>{health.current.binary}</code> ({health.binary.state})</dd>
      <dt class="text-zinc-500">VM asset revision</dt><dd><code>{health.current.assets}</code> ({health.assets.state})</dd>
      <dt class="text-zinc-500">Profile revision</dt><dd><code>{health.profiles.revision}</code></dd>
      <dt class="text-zinc-500">Architectures</dt><dd>{architectures.join(', ')}</dd>
      <dt class="text-zinc-500">Current asset base</dt><dd><a class="break-all text-blue-600 underline" href={assetBase}>{assetBase}</a></dd>
      <dt class="text-zinc-500">Health JSON</dt><dd><a class="text-blue-600 underline" href="/health.json">/health.json</a></dd>
      <dt class="text-zinc-500">Profile catalog JSON</dt><dd><a class="break-all text-blue-600 underline" href={health.profiles.source}>{health.profiles.source}</a></dd>
      <dt class="text-zinc-500">Manifest BLAKE3</dt><dd><code class="break-all">{health.manifest_blake3}</code></dd>
    </dl>
  </section>

  <section class="mt-6 border border-zinc-200 p-5">
    <h2 class="text-xl font-semibold text-black">Capsem Binaries</h2>
    <div class="mt-4 overflow-x-auto">
      <table class="w-full min-w-[900px] border-collapse text-sm">
        <thead>
          <tr class="border-b border-zinc-200 text-left text-zinc-500">
            <th class="py-2 pr-4 font-medium">Version</th>
            <th class="py-2 pr-4 font-medium">Capsem binary</th>
            <th class="py-2 pr-4 font-medium">Description</th>
            <th class="py-2 pr-4 font-medium">Download</th>
            <th class="py-2 pr-4 font-medium">Bytes</th>
            <th class="py-2 pr-4 font-medium">SHA-256</th>
            <th class="py-2 pr-4 font-medium">Binary SBOM</th>
          </tr>
        </thead>
        <tbody>
          {binaries.length > 0 ? binaries.map((file) => (
            <tr class="border-b border-zinc-100 align-top">
              <td class="py-3 pr-4"><code>{health.current.binary}</code></td>
              <td class="py-3 pr-4">{file.name}</td>
              <td class="py-3 pr-4 text-zinc-600">{binaryDescription(file.name)}</td>
              <td class="py-3 pr-4"><a class="break-all text-blue-600 underline" href={file.url}>{file.url}</a></td>
              <td class="py-3 pr-4">{byteLabel(file.size)}</td>
              <td class="py-3 pr-4"><code class="break-all">{file.sha256}</code></td>
              <td class="py-3 pr-4">
                {hostSbom ? <a class="break-all text-blue-600 underline" href={hostSbom.url}>{hostSbom.name}</a> : 'Not published'}
              </td>
            </tr>
          )) : (
            <tr>
              <td class="py-4 pr-4 text-zinc-600" colspan="7">
                No Capsem binary package metadata is published in this channel manifest.
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-6 border border-zinc-200 p-5">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 class="text-xl font-semibold text-black">Profiles</h2>
        <p class="mt-1 text-sm text-zinc-600">Profile pages are generated from the published profile catalog JSON.</p>
      </div>
      <a class="text-sm font-medium text-blue-600 underline" href={health.profiles.source}>Catalog JSON</a>
    </div>
    <div class="mt-4 grid gap-4 md:grid-cols-2">
      {profiles.map((profile) => (
        <article class="border border-zinc-200 p-4">
          <h3 class="text-lg font-semibold text-black">
            <a class="text-blue-600 underline" href={profilePagePath(profile.id)}>{profile.name}</a>
          </h3>
          <p class="mt-1 text-sm text-zinc-600">{profile.description}</p>
          <dl class="mt-4 grid gap-2 text-sm sm:grid-cols-[9rem_1fr]">
            <dt class="text-zinc-500">ID</dt><dd><code>{profile.id}</code></dd>
            <dt class="text-zinc-500">Revision</dt><dd><code>{profile.revision}</code></dd>
            <dt class="text-zinc-500">Architectures</dt><dd>{Object.keys(profile.assets?.arch ?? {}).sort().join(', ')}</dd>
            <dt class="text-zinc-500">Files</dt><dd>{Object.keys(profile.files ?? {}).length}</dd>
          </dl>
        </article>
      ))}
    </div>
  </section>

  <section class="mt-6 border border-zinc-200 p-5">
    <h2 class="text-xl font-semibold text-black">Asset Release History</h2>
    <div class="mt-4 overflow-x-auto">
      <table class="w-full min-w-[760px] border-collapse text-sm">
        <thead>
          <tr class="border-b border-zinc-200 text-left text-zinc-500">
            <th class="py-2 pr-4 font-medium">Version</th>
            <th class="py-2 pr-4 font-medium">Date</th>
            <th class="py-2 pr-4 font-medium">State</th>
            <th class="py-2 pr-4 font-medium">Deprecated</th>
            <th class="py-2 pr-4 font-medium">Min binary</th>
            <th class="py-2 pr-4 font-medium">Architectures</th>
          </tr>
        </thead>
        <tbody>
          {assetReleases.map((release) => (
            <tr class="border-b border-zinc-100">
              <td class="py-3 pr-4"><code>{release.version}</code></td>
              <td class="py-3 pr-4">{release.date}</td>
              <td class="py-3 pr-4">{release.state}</td>
              <td class="py-3 pr-4">{String(release.deprecated)}</td>
              <td class="py-3 pr-4"><code>{release.min_binary}</code></td>
              <td class="py-3 pr-4">{(release.arches ?? []).join(', ')}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

</ReleaseLayout>
