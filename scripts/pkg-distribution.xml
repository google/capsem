<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Capsem</title>
    <organization>com.capsem</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" require-scripts="true" hostArchitectures="arm64"/>
    <allowed-os-versions>
        <os-version min="13.0"/>
    </allowed-os-versions>
    <welcome file="welcome.html"/>
    <pkg-ref id="com.capsem.pkg"/>
    <choices-outline>
        <line choice="default">
            <line choice="com.capsem.pkg"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="com.capsem.pkg" visible="false">
        <pkg-ref id="com.capsem.pkg"/>
    </choice>
    <pkg-ref id="com.capsem.pkg" version="__VERSION__" onConclusion="none">capsem.pkg</pkg-ref>
</installer-gui-script>
